[
  {
    "name": "AI智能答题",
    "url": "http://127.0.0.1:5000/api/answer",
    "method": "post",
    "type": "GM_xmlhttpRequest",
    "contentType": "json",
    "data": {
      "question": "${title}",
      "options": "${options}",
      "type": "${type}"
    },
    "handler": "return (res)=>res.success && res.ocs_format ? [res.ocs_format] : []"
  }
]